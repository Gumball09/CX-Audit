# ===========================================================================
# CX Audit Backend — environment template
# Copy this file to `.env.local` and fill in the values. Nothing here is
# committed; `.env.local` is git-ignored.
# ===========================================================================

# ---- Server ----
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
# Comma-separated allowed origins for the dashboard, or * for any (dev only).
CORS_ORIGIN=http://localhost:3000

# ---- Auth (JWT) ----
# REQUIRED in production. Use a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=
JWT_EXPIRES_IN=12h

# ---- AWS credentials ----
# Needed for S3, SQS and DynamoDB. On ECS/EC2 you can omit these and rely on an
# attached IAM role instead.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- S3 ----
# Source bucket holding the raw call recordings (this app only reads it).
S3_RECORDING_BUCKET=cz-scaler-support-calls
# Optional prefix to scope which recordings get processed (e.g. Scaler/).
S3_RECORDING_PREFIX=
# Destination bucket for transcripts + audit JSON (this app reads & writes it).
# May be the same bucket as the source if you prefer.
S3_OUTPUT_BUCKET=
S3_TRANSCRIPTION_PREFIX=transcriptions/
S3_AUDIT_PREFIX=audits/

# ---- SQS (paste the URLs printed by `npm run infra:create`) ----
SQS_TRANSCRIPTION_QUEUE_URL=
SQS_AUDIT_QUEUE_URL=
SQS_BATCH_SIZE=5
SQS_WAIT_TIME_SECONDS=20
# After this many failed deliveries a message is sent to its DLQ. MUST match the
# queue's RedrivePolicy.maxReceiveCount (create-infra.ts uses this value). Also
# used to escalate the final failed attempt to a critical Sentry alert.
SQS_MAX_RECEIVE_COUNT=5
# Max parallel jobs a single worker process handles. It only uses this much when
# the queue is busy and idles to ~0 when empty. Raise to drain bursts faster
# (mind your OpenAI rate limits). See docs/backend/SCALING.md.
WORKER_CONCURRENCY=5

# ---- DynamoDB table names (defaults shown; only change to override) ----
DDB_USERS_TABLE=cx_users
DDB_TEAMS_TABLE=cx_teams
DDB_AUDITS_TABLE=cx_audits
# Super-admin-configurable recording-filename regex patterns.
DDB_PATTERNS_TABLE=cx_recording_patterns
# Time-bucketed performance aggregates (per-agent + per-team day/month/year).
DDB_PERFORMANCE_TABLE=cx_performance
# Singleton platform settings (the OpenAI models a super_admin picks at runtime).
DDB_SETTINGS_TABLE=cx_settings

# ---- OpenAI ----
# If OPENAI_API_KEY is blank the pipeline runs in STUB mode (fake transcript +
# deterministic scores) so you can test wiring without spending tokens.
OPENAI_API_KEY=
# These are FALLBACKS only. A super_admin can override the models at runtime from
# the dashboard (Settings) — stored in DDB_SETTINGS_TABLE and used within ~60s.
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_AUDIT_MODEL=gpt-4o

# ---- Sentry (error / urgent-alert reporting) ----
# Write-only ingest DSN. Leave blank to disable (local/stub mode). Reports
# worker crashes, OpenAI credit/quota exhaustion, and DLQ-bound failures so a
# human is alerted via Sentry's alert rules. Required (recommended) in prod.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# Performance tracing sample rate (0 = error reporting only).
SENTRY_TRACES_SAMPLE_RATE=0
